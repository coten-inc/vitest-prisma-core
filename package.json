{
  "name": "@coten-inc/vitest-prisma-core",
  "version": "0.1.0",
  "description": "Transaction-isolated Prisma test environments for Vitest. Forked from @quramy/jest-prisma-core with concurrent nested transaction support.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vitest",
    "prisma",
    "test",
    "transaction",
    "rollback"
  ],
  "author": "COTEN Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/coten-inc/vitest-prisma-core.git"
  },
  "homepage": "https://github.com/coten-inc/vitest-prisma-core",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
